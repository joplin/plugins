		},
		{
			"src": "screenshots/search.png",
			"label": "Full-text search with keyword highlighting"
		},
		{
			"src": "screenshots/context-menu.png",
			"label": "Right-click context menu"
		}
	],
	"_npm_package_name": "joplin-plugin-explorer"
